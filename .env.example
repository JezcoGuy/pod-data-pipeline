# ── Core ──────────────────────────────────────────────────────────────────
BRAND_ID=your_brand_id
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Your store's base/reporting currency (e.g. GBP, USD, AUD, NZD)
# NOTE: The pipeline does not currently convert currencies.
# All _gbp-named columns store values in this currency.
# Multi-currency FX support is planned — see SETUP.md.
STORE_CURRENCY=GBP

# ── Shopify ───────────────────────────────────────────────────────────────
# NOTE (2026+): Shopify no longer issues permanent access tokens for new
# Custom Apps. Use a Private App (if still available on your plan) or
# implement token rotation. Work through this with Claude Chat during
# Step 2 onboarding — Shopify's auth flow has changed significantly.
#
# Bare store handle only — NOT the full URL
# e.g. if your store is my-store.myshopify.com, enter: my-store
SHOPIFY_STORE_NAME=your-store-handle
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx

# ── Meta Ads ──────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=xxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxx
# Meta API page size — reduce to 25 or 50 if you see 500 errors
# on accounts with large numbers of creatives/ads
META_PAGE_SIZE=100

# ── GA4 ───────────────────────────────────────────────────────────────────
# GA4 — uses Service Account authentication (NOT OAuth)
# Setup steps:
# 1. Create a Google Cloud project (or use existing)
# 2. Enable Google Analytics Data API
# 3. Create a Service Account
# 4. Download the JSON key file — save to server (e.g. /opt/your-brand/ga4_key.json)
# 5. In GA4 property settings → Property Access Management → add service account email as Viewer
# 6. Set GA4_PROPERTY to your numeric Property ID (found in GA4 Admin → Property Settings)
# NOTE: If your org policy blocks service account key creation (iam.disableServiceAccountKeyCreation)
# work through the keyless/ADC alternative with Claude Chat during Step 2 onboarding
GA4_PROPERTY=000000000
GA4_KEY_FILE=/opt/YOUR_BRAND_ID/ga4_key.json

# ── Google Search Console ─────────────────────────────────────────────────
GSC_SITE_URL=sc-domain:your-domain.com
# GSC uses OAuth — token stored as gsc_token.pickle after first auth

# ── PageSpeed ─────────────────────────────────────────────────────────────
PAGESPEED_API_KEY=xxxxxxxxxxxx
PAGESPEED_URLS=https://your-domain.com,https://your-domain.com/collections/all

# ── Gelato (optional) ─────────────────────────────────────────────────────
# Gelato API — costs stored in your Gelato account currency
GELATO_API_KEY=xxxxxxxxxxxx

# ── Printify (optional) ───────────────────────────────────────────────────
PRINTIFY_TOKEN=xxxxxxxxxxxx
PRINTIFY_SHOP_ID=xxxxxxxxxxxx

# ── Klaviyo (optional) ────────────────────────────────────────────────────
KLAVIYO_API_KEY=pk_xxxxxxxxxxxx

# ── PayPal (optional) ─────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=xxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxx

# ── Klarna (optional) ─────────────────────────────────────────────────────
KLARNA_API_KEY=xxxxxxxxxxxx
KLARNA_API_SECRET=xxxxxxxxxxxx

# ── Monzo (optional — UK only) ────────────────────────────────────────────
MONZO_ACCESS_TOKEN=xxxxxxxxxxxx
MONZO_ACCOUNT_ID=xxxxxxxxxxxx

# ── Amex (optional — CSV import, no API) ─────────────────────────────────
# No API key needed — drop CSV statements into data/amex/inbox/

# ── Email Alerts (nightly script) ─────────────────────────────────────────
# Supports any SMTP provider — Gmail, Fastmail, SendGrid, Mailgun etc
SMTP_HOST=smtp.your-provider.com
# Use 587 for STARTTLS (recommended — works on most VPS providers)
# Use 465 for implicit SSL (may be blocked on some providers e.g. Hetzner)
SMTP_PORT=587
SMTP_USER=alerts@your-domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=alerts@your-domain.com
SMTP_TO=you@your-domain.com

# ── Task Manager PIN ──────────────────────────────────────────────────────
TASK_PIN=your_6_digit_pin

# ── NocoDB ────────────────────────────────────────────────────────────────
NOCODB_API_TOKEN=xxxxxxxxxxxx
NOCODB_BASE_URL=http://localhost:8080

# ── Gelato Alert Thresholds ───────────────────────────────────────────────
GELATO_ALERT_HOURS=48
RETURNED_ALERT_DAYS=60
LATE_DELIVERY_DAYS=7
REFUND_ALERT_DAYS=7
